// Prisma schema for the User Admin Dashboard
// Unifies people across Amplitude, Wix and Typeform into one User record,
// matched primarily by email. Raw per-source data is kept alongside the
// unified record so nothing is lost in the merge.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// Admins allowed to sign in to the dashboard. Belt-and-suspenders alongside
// the ADMIN_EMAILS env allowlist checked in NextAuth callbacks.
model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}

// The unified person record shown in the dashboard.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Best-known demographic fields, merged from whichever source has them.
  location String?
  company  String?
  jobTitle String?
  phone    String?

  // Field name -> value for anything an admin has manually edited on this
  // page. Syncs check this before overwriting a field, so a manual edit
  // survives the next "Sync now" instead of being silently reverted.
  overrides Json?

  amplitudeProfile   AmplitudeProfile?
  wixContact         WixContact?
  typeformResponses  TypeformResponse[]
  customFieldValues  CustomFieldValue[]

  // Resolved from Wix's "Partner Email" custom field (see syncWix). Set
  // symmetrically on both users when linked, so `partner` is always the
  // other person regardless of which side you look from.
  partnerId String? @unique
  partner   User?   @relation("UserPartner", fields: [partnerId], references: [id])
  partnerOf User?   @relation("UserPartner")

  @@index([email])
}

// Manual user_id -> email mapping, for apps that don't send email as an
// Amplitude user property. Imported once (or periodically) by an admin via
// /api/admin/amplitude-emails, and consulted by the Amplitude sync as a
// fallback when an event has no email user property.
model AmplitudeEmailMap {
  amplitudeUserId String   @id
  email           String
  importedAt      DateTime @default(now())
}

// One row per person per Amplitude project (Amplitude's own user id kept
// for re-sync matching).
model AmplitudeProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amplitudeUserId String    @unique
  deviceType      String?
  platform        String?
  lastSeenAt      DateTime?
  firstSeenAt     DateTime?
  totalEvents     Int?
  // Lifetime counts of specific event types, recomputed from full history
  // on every sync (see syncAmplitude for the exact event names counted).
  sessionCount        Int?
  goalCompletedCount  Int?
  goalSharedCount     Int?
  partnerInvitedCount Int?
  // Best-available proxy for "partner accepted the invite": there's no
  // event literally named that, so this is set from household_canvas_unlocked
  // (fires once a partner has successfully paired).
  partnerAcceptedAt   DateTime?
  // UUID of whoever most recently accepted a shared goal onto the
  // household canvas (accepted_by on goal_card_accepted_onto_household_canvas)
  // - the best available signal for "the partner's ID."
  partnerUuid         String?
  // Raw Amplitude user properties, kept as-is for fields we haven't
  // promoted to first-class columns yet.
  properties      Json?
  // Recent behavioral events, most-recent-first.
  recentEvents    Json?
  // Field name -> value for anything an admin has manually edited - see
  // User.overrides for how syncs respect this.
  overrides       Json?
  syncedAt        DateTime  @default(now())
}

// One row per Wix contact.
model WixContact {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wixContactId String   @unique
  address      Json?
  membership   String?
  orders       Json?
  labels       Json?
  // How the contact was created on Wix (WIX_FORMS, WIX_STORES, IMPORT, etc).
  source            String?
  wixCreatedDate    DateTime?
  lastActivityAt    DateTime?
  lastActivityType  String?
  birthdate         String?
  locale            String?
  // Marketing-email opt-in status (NOT_SET, PENDING, SUBSCRIBED, UNSUBSCRIBED).
  subscriptionStatus String?
  // Custom fields defined in the Wix site's contact schema, kept as-is.
  extendedFields    Json?
  // Field name -> value for anything an admin has manually edited - see
  // User.overrides for how syncs respect this.
  overrides    Json?
  syncedAt     DateTime @default(now())
}

enum CustomFieldType {
  TEXT // short plain text
  LONG_TEXT // multi-line description
  LINK // URL
  LABEL // admin-defined multi-select tags, see labelOptions
}

// An admin-defined custom field, created once from any user's page and
// then reusable across every person (e.g. a "Priority" label field
// defined while editing one person shows up as an option to add on
// everyone else's page too), rather than being redefined per-person.
model CustomFieldDefinition {
  id           String            @id @default(cuid())
  name         String            @unique
  type         CustomFieldType
  // Only used when type = LABEL - the fixed set of tags an admin can pick
  // from when assigning this field to a person.
  labelOptions String[]
  createdAt    DateTime          @default(now())
  values       CustomFieldValue[]
}

// One person's value for one custom field.
model CustomFieldValue {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  fieldId   String
  field     CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  // Used for TEXT / LONG_TEXT / LINK.
  value       String?
  // Used for LABEL - a subset of field.labelOptions.
  labelValues String[]
  updatedAt   DateTime @updatedAt

  @@unique([userId, fieldId])
}

// One row per Typeform response. A user can have many (one per form
// submission); userId is nullable because a response's email may not
// resolve to a known user until matched.
model TypeformResponse {
  id          String    @id @default(cuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  formId      String
  formTitle   String?
  responseId  String    @unique
  answers     Json
  submittedAt DateTime?
  syncedAt    DateTime  @default(now())

  @@index([formId])
}
