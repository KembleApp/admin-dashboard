# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it's already in .gitignore.

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/admin_dashboard"

# --- NextAuth (admin login) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Comma-separated allowlist of emails permitted to sign in as admins.
ADMIN_EMAILS="you@yourcompany.com"

# --- Typeform ---
# Personal access token from https://admin.typeform.com/account#/section/tokens
TYPEFORM_TOKEN=""

# --- Amplitude ---
# From Amplitude project Settings > Projects > (your project) > General.
# Note: these are direct API credentials for THIS app's server-side sync job.
# They are separate from any Amplitude connector authorized inside Cowork/Claude —
# a deployed app can't reuse a Cowork chat connector, it needs its own keys.
AMPLITUDE_API_KEY=""
AMPLITUDE_SECRET_KEY=""

# --- Wix ---
# API key + Site ID from the Wix Developers Center (Headless / REST API app).
# Same note as above: separate credentials from any Cowork Wix connector.
WIX_API_KEY=""
WIX_SITE_ID=""
